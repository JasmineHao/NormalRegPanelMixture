sprintf("N = %d",N)
sprintf("T = %d",T)
R <- matrix(0,nrow=N,ncol=M)
if (sum(alpha) != 1){
alpha <- alpha / sum(alpha)
}
if (length(alpha) != M | length(mu) != M){
stop('M must be the size of alpha')
}
prior <- runif(N)
alpha.cum <- c(0,cumsum(alpha))
if (M > 1){
for (m in 1:M){
lb <-  alpha.cum[m]
ub <- alpha.cum[m+1]
R[,m] <- 1 * ((prior <= ub) & (prior > lb))
}
}else{
R <- matrix(1,nrow=N,ncol=M)
}
Y = matrix(0,T,N)
if ((q != 0) && (is.null(X))){
