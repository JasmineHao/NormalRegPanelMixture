return(list(phi=phi,Data=Data))
}
getEstimate <- function(Data,nrep,an,cl){
lr.crit <- matrix(0.0,nr=nrep,ncol=3)
lr.estimate <- matrix(0.0,nr=nrep,ncol=1)
lr.size <- matrix(0.0,nr=nrep,ncol=1) #Nomimal size
