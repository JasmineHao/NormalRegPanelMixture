t = 1 /  df.M2$T,
n = 1 /  df.M2$N,
an = log( df.M2$an/ (1 - df.M2$an )),
omega = df.M2$omega)
an.model.M2 <- lm(y ~ t + n + an + omega , data=fit.data,na.action = na.omit)
print(summary(an.model.M2))
