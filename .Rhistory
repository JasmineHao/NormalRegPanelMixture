mu = phi$mu
gamma = phi$gamma
beta = phi$beta
X = phi$X
Data <- replicate(nrep,generateData(alpha,mu,sigma,gamma,beta,N,T,M,p,q,X=X))
return(list(phi=phi,Data=Data))
}
