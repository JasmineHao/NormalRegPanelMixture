#crit.df.boot[T,M] <- paste(round(lr.crit.boot ,2),collapse = ",")
print(lr.estimate)
print(lr.crit)
}
}
lr.crit <- try(regpanelmixCrit(y=data$Y, x=data$X, parlist=out.h0$parlist ,parallel = TRUE)$crit)
