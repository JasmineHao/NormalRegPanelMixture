alpha = alphaset[[1]]
cl <- makeCluster(6)
t <- Sys.time()
phi = list(alpha = alpha,mu = mu,sigma = sigma, gamma = gamma, beta = beta, N = N, T = T, M = M, p = p, q = q)
phi.data.pair <- GenerateSample(phi,nrep)
